# Copy to .env — never commit .env
DATABASE_URL="file:./dev.db"
SESSION_SECRET="generate-a-long-random-string-for-signing-cookie-attributes-use-openssl-rand-base64-32"
NODE_ENV="development"
PORT=3000
# Comma-separated browser origins for CORS (empty = same-origin only / no CORS for browsers)
CORS_ORIGINS="http://localhost:3000"

# Optional for local seeding:
# If omitted, seed keeps existing user password values unchanged.
SEED_ADMIN_PASSWORD="ChangeMe_Admin_123!"
SEED_USER_PASSWORD="ChangeMe_User_123!"
SEED_AUDITOR_PASSWORD="ChangeMe_Auditor_123!"
